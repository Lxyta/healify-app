                  "current_weight_kg": 70.5,
                  "target_weight_kg": 65.0,
                  "activity_level": "MODERATE",
                  "diet_preference": "OMNIVORE",
                  "daily_calorie_goal": 2000,
                  "daily_protein_g": 80,
                  "exercise_frequency": 4,
                  "exercise_duration": 45
